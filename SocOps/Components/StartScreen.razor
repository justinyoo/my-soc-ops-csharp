<div class="mc-screen flex flex-col items-center justify-center">
    <div class="max-w-sm w-full text-center mc-reveal">
        <h1 class="mc-title text-4xl mb-3 mc-start-float">Soc Ops</h1>
        <p class="mc-subtitle mb-8">Village Social Bingo</p>

        <div class="mc-panel mb-8 mc-reveal mc-reveal-delay-1">
            <h2 class="mc-title text-sm mb-4">Quest Log</h2>
            <ul class="text-left text-gray-700 text-lg space-y-2">
                <li>- Find players matching each block challenge.</li>
                <li>- Mark a square when you make a match.</li>
                <li>- Build 5 blocks in a row to win.</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="mc-btn mc-reveal mc-reveal-delay-2">
            Start New World
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
