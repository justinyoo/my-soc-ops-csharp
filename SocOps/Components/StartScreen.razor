<div class="mc-screen flex flex-col items-center justify-center">
    <div class="mc-start-hero">
        <div class="mc-start-hero-text mc-reveal">
            <h1 class="mc-title mc-title-glint">Soc Ops</h1>
            <p class="mc-subtitle">Village Social Bingo</p>
            <p class="mc-note">Find people matching each square challenge. Mark their square when you make a match. Get 5 in a row to win!</p>
        </div>
        <div class="mc-start-hero-grid mc-reveal mc-reveal-delay-1 mc-start-float">
            <div class="mc-mini-grid">
                <div class="mc-mini-square winning"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square marked"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square winning"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square marked"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square winning"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square marked"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square winning"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square"></div>
                <div class="mc-mini-square marked"></div>
                <div class="mc-mini-square winning"></div>
            </div>
        </div>
    </div>

    <div class="mc-start-steps mc-reveal mc-reveal-delay-2">
        <div class="mc-how-step"><span class="mc-start-badge">1</span> Find a player matching the square</div>
        <div class="mc-how-step"><span class="mc-start-badge">2</span> Mark their square on your board</div>
        <div class="mc-how-step"><span class="mc-start-badge">3</span> Get 5 in a row to win</div>
    </div>

    <button @onclick="OnStart" class="mc-btn mc-reveal mc-reveal-delay-3">⚔ Start New World ⚔</button>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
