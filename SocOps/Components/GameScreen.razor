@using SocOps.Models

<div class="mc-screen flex flex-col min-h-full">
    <header class="mc-header flex items-center justify-between p-3 mb-4 mc-reveal">
        <button
            @onclick="OnReset"
            class="mc-btn mc-btn-secondary w-16">
            Exit
        </button>
        <h1 class="mc-title text-sm text-center">Soc Ops Bingo</h1>
        <div class="w-16"></div>
    </header>

    <p class="mc-note text-center text-sm py-2 px-4 mb-4 mc-reveal mc-reveal-delay-1">
        Mine conversations and mark squares when you find a match.
    </p>

    @if (HasBingo)
    {
        <div class="mc-banner text-center py-2 mb-4 mc-reveal mc-reveal-delay-2">
            Bingo unlocked! Legendary line completed.
        </div>
    }

    <div class="flex-1 flex items-center justify-center">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
