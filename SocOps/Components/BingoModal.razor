<div class="fixed inset-0 mc-modal-backdrop flex items-center justify-center p-4 z-50">
    <div class="mc-modal p-6 max-w-xs w-full text-center mc-reveal">
        <div class="mc-title text-lg mb-4 mc-start-float">Level Up</div>
        <h2 class="mc-title text-3xl text-amber-500 mb-2">Bingo!</h2>
        <p class="text-gray-700 text-lg mb-6">You crafted a full line of matches.</p>

        <button
            @onclick="OnDismiss"
            class="mc-btn">
            Keep Mining
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
